{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "lib": ["es5", "es6", "esnext", "dom", "webworker"],
    "allowJs": true,
    "declaration": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  }
}
